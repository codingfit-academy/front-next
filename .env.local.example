# 로컬 개발용 — 이 파일을 .env.local로 복사해서 사용하세요
# 서버 배포 시에는 docker-compose에서 자동으로 설정됩니다
#
# ※ 모든 env 는 src/config.ts 한 곳에서 읽습니다. 새 변수는 거기에 추가하세요.
#   (브라우저 노출 값은 반드시 NEXT_PUBLIC_ 접두사 필요)

# 로컬에서 백엔드 실행 중일 때
NEXT_PUBLIC_API_URL=http://localhost:8000

# 서버 배포 환경에서는 아래처럼 자동 설정됩니다 (수정 불필요)
# NEXT_PUBLIC_API_URL=https://api.{username}.codingfit.kr
